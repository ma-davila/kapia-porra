# ---- Database (Neon Postgres) ----
# When you add the Neon integration in the Vercel dashboard this is set automatically.
# For local dev, paste your Neon "pooled" connection string here.
DATABASE_URL="postgresql://user:password@host/dbname?sslmode=require"

# ---- Auth / sessions ----
# Random secret used to sign login cookies. Generate with: openssl rand -hex 32
SESSION_SECRET="change-me-to-a-long-random-string"
# Code your Kapia colleagues type once when they register their account.
INVITE_CODE="kapia2026"

# ---- Admin override page (/admin) ----
ADMIN_PASSWORD="choose-an-admin-password"

# ---- Football results API (football-data.org, free tier) ----
# Get a free key at https://www.football-data.org/client/register
FOOTBALL_API_KEY=""

# ---- Slack daily digest ----
# Option A (simplest): an Incoming Webhook. Posts the digest, but cannot reply in
# a thread. https://api.slack.com/messaging/webhooks
SLACK_WEBHOOK_URL=""

# Option B (recommended): a Bot token + channel ID. Enables the threaded
# "yesterday's hits" reply under the digest. Create/extend your Slack app:
# OAuth & Permissions → add bot scope "chat:write" → Install → copy the
# "Bot User OAuth Token" (xoxb-...). Then /invite the bot to your channel and
# copy the channel ID (channel details → bottom). If both A and B are set, B wins.
SLACK_BOT_TOKEN=""
SLACK_CHANNEL_ID=""

# Public URL of the app, used for the "predict now" link in the Slack message.
# On Vercel this is auto-detected; set it only to override.
APP_URL=""

# ---- Cron security ----
# Random secret. Vercel Cron sends this automatically once set in project env.
# Generate with: openssl rand -hex 32
CRON_SECRET="change-me-to-a-long-random-string"
